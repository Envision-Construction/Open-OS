# ─── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Optional LLM providers ──────────────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── DLP Proxy ────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=open-os-prod
# Path to service account key (local dev only — GKE uses Workload Identity)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-sa-key.json

# ─── Open Web UI ──────────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=change-me-in-production

# ─── Evolution API (WhatsApp) ────────────────────────────────────────────────
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_DB_PASSWORD=evolution_pass

# ─── Slack OAuth ─────────────────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Legacy direct tokens (optional — OAuth flow populates these automatically)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
